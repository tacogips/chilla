{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "marky",
  "version": "0.1.0",
  "identifier": "com.tacogips.marky",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "marky",
        "width": 1480,
        "height": 920,
        "minWidth": 960,
        "minHeight": 640,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
